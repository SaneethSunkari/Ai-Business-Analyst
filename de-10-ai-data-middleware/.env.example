# Copy this file to .env and fill in your values
# cp .env.example .env

# ── OpenAI ───────────────────────────────────────────────────────────────────
# Required: your OpenAI API key (used for natural-language → SQL generation)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini

# Enable TokenFirewall by default. When no external gateway URL is provided,
# the backend can start an embedded local gateway for single-service deploys
# like Railway. In docker compose, the API uses the separate tokenfirewall
# service automatically.
ENABLE_TOKENFIREWALL=1
TOKENFIREWALL_PORT=8787

# Optional: route OpenAI-compatible calls through TokenFirewall.
# For docker compose, use the service name:
TOKENFIREWALL_BASE_URL=http://tokenfirewall:8787
# Or set OPENAI_BASE_URL directly:
# OPENAI_BASE_URL=http://tokenfirewall:8787/v1

# TokenFirewall service settings used by docker compose
TOKENFIREWALL_GATEWAY_MODE=normal
TOKENFIREWALL_CHEAP_MODEL=gpt-4o-mini
TOKENFIREWALL_DEFAULT_MODEL=gpt-4o
TOKENFIREWALL_STRONG_MODEL=gpt-4o
TOKENFIREWALL_DAILY_TOKEN_BUDGET=50000
TOKENFIREWALL_MONTHLY_TOKEN_BUDGET=1000000
TOKENFIREWALL_FORCE_MOCK=0

# Optional local demo CSV seed directory for docker compose.
# Put the 12 healthcare CSV files there or override this path.
CSV_SEED_DIR=./demo_db/csv

# ── Supabase control-plane setup ─────────────────────────────────────────────
# Public project URL, used by frontend/backend clients
SUPABASE_URL=https://your-project-ref.supabase.co

# Public anon key for browser-safe client usage
SUPABASE_ANON_KEY=eyJ...

# Server-only key for backend admin tasks against Auth/Data APIs
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Project ref, used by the Supabase Management API helper
SUPABASE_PROJECT_REF=your-project-ref

# Optional: direct Postgres URL for applying migrations
SUPABASE_DB_URL=postgresql://postgres:YOUR-PASSWORD@db.your-project-ref.supabase.co:5432/postgres

# Optional: Supabase Personal Access Token for the Management API
SUPABASE_MANAGEMENT_PAT=sbp_...

# ── Supabase control-plane runtime ───────────────────────────────────────────
# Server-side REST access used for persistent saved sources and query history
CONTROL_PLANE_ENCRYPTION_KEY=
CONTROL_PLANE_ORGANIZATION_ID=
CONTROL_PLANE_ACTOR_USER_ID=

# Optional bootstrap helper inputs
CONTROL_PLANE_OWNER_EMAIL=owner@example.com
CONTROL_PLANE_OWNER_PASSWORD=ChangeMe123!
CONTROL_PLANE_OWNER_NAME=Control Plane Owner
CONTROL_PLANE_ORGANIZATION_NAME=Default Workspace
CONTROL_PLANE_ORGANIZATION_SLUG=default-workspace
